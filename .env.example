# ============================================================================
# NebulaCloud — example environment file
# Copy to `.env` only when you want to override values below. Docker Compose loads
# this file from the repo by default, then merges an optional `.env` (see docker-compose.yml).
# ============================================================================

# ---------- Core ----------
NEBULA_ENV=development                    # development | staging | production
NEBULA_LOG_LEVEL=debug                    # debug | info | warn | error
NEBULA_SERVICE_NAME=nebula-api

# ---------- API server ----------
NEBULA_API_HOST=0.0.0.0
NEBULA_API_PORT=8080
NEBULA_API_READ_TIMEOUT=15s
NEBULA_API_WRITE_TIMEOUT=15s
NEBULA_API_IDLE_TIMEOUT=60s
NEBULA_API_SHUTDOWN_TIMEOUT=20s
NEBULA_API_PUBLIC_URL=http://api.nebula.localhost
NEBULA_DASHBOARD_URL=http://app.nebula.localhost

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula_dev_password
POSTGRES_DB=nebula
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h

# Composed DSN (auto-built by config if empty)
NEBULA_DATABASE_URL=

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
NEBULA_REDIS_URL=

# ---------- Auth / JWT ----------
# Generate strong values for production:
#   openssl rand -hex 32
NEBULA_JWT_SECRET=change-me-please-use-openssl-rand-hex-32
NEBULA_JWT_ISSUER=nebula-cloud
NEBULA_JWT_ACCESS_TTL=15m
NEBULA_JWT_REFRESH_TTL=720h
NEBULA_PASSWORD_PEPPER=change-me-pepper

# AES-256-GCM key: base64 encoding of exactly 32 raw bytes (44 chars with padding).
# Generate: openssl rand -base64 32
# Dev-only default below (do not use in production):
NEBULA_SECRETS_KEY=bmVidWxhLWRldi1zZWNyZXRzLWtleS0zMmJ5dGVzISE=

# ---------- GitHub App ----------
NEBULA_GITHUB_APP_ID=
NEBULA_GITHUB_APP_CLIENT_ID=
NEBULA_GITHUB_APP_CLIENT_SECRET=
NEBULA_GITHUB_APP_WEBHOOK_SECRET=
NEBULA_GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem

# ---------- Build / Runtime ----------
NEBULA_REGISTRY_URL=registry.nebula.localhost:5000
NEBULA_REGISTRY_INSECURE=true
NEBULA_BUILDER_IMAGE=paketobuildpacks/builder-jammy-base:latest
NEBULA_DOCKER_HOST=unix:///var/run/docker.sock
NEBULA_RUNTIME_NETWORK=nebula_apps
NEBULA_BASE_DOMAIN=nebula.localhost

# ---------- Observability ----------
NEBULA_METRICS_ENABLED=true
NEBULA_METRICS_PORT=9100
NEBULA_TRACING_ENABLED=false
NEBULA_OTLP_ENDPOINT=

# ---------- Rate limiting ----------
NEBULA_RATE_LIMIT_RPS=20
NEBULA_RATE_LIMIT_BURST=40

# ---------- CORS ----------
NEBULA_CORS_ALLOWED_ORIGINS=http://app.nebula.localhost,http://localhost:3000

# ---------- Grafana (compose only) ----------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
