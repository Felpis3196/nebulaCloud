{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "schemaVersion": 39,
  "tags": ["nebula", "platform"],
  "title": "NebulaCloud — Platform Overview",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "API up",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"nebula-api\"}", "refId": "A" }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "type": "timeseries",
      "title": "API requests / sec",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(nebula_http_requests_total[1m]))",
          "refId": "A",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API p95 latency (s)",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(nebula_http_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "API logs (last 100)",
      "id": 4,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"api\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
