# =============================================================================
# NebulaCloud — frontend environment
# Copy to `.env.local` for local development.
# =============================================================================

# Public NebulaCloud API URL. The dashboard talks to it directly from the
# browser (with CORS allowed by NEBULA_CORS_ALLOWED_ORIGINS on the backend).
NEXT_PUBLIC_API_URL=http://api.nebula.localhost

# Public app URL — used for OAuth callbacks and absolute share links.
NEXT_PUBLIC_APP_URL=http://app.nebula.localhost

# Optional: GitHub repository link surfaced in the landing page footer.
NEXT_PUBLIC_GITHUB_URL=https://github.com/nebulacloud/nebula
